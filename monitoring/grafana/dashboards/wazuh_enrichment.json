{
  "id": null,
  "uid": "wazuh-enrichment-v1",
  "title": "Wazuh IOC Enrichment Pipeline",
  "description": "Real-time monitoring of the Wazuh IOC enrichment pipeline",
  "tags": [
    "wazuh",
    "security",
    "enrichment"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Alerts Processed / min",
      "description": "Rate of alerts successfully processed by the enrichment worker",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity"
          },
          "unit": "short",
          "displayName": "${__series.name}"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (risk_level) (rate(enrichment_alerts_processed_total[1m])) * 60",
          "legendFormat": "{{risk_level}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Risk Level Breakdown",
      "description": "Total alerts processed by risk level",
      "type": "piechart",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "CRITICAL"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#F2495C",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "HIGH"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF9830",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "MEDIUM"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FADE2A",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "LOW"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "INFO"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#5794F2",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "sum by (risk_level) (enrichment_alerts_processed_total)",
          "legendFormat": "{{risk_level}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "API Response Times per Provider (p50)",
      "description": "Enrichment API latency per provider in seconds",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 16,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "enrichment_api_latency_seconds{quantile=\"0.5\", provider=\"virustotal\"}",
          "legendFormat": "VirusTotal",
          "refId": "A"
        },
        {
          "expr": "enrichment_api_latency_seconds{quantile=\"0.5\", provider=\"abuseipdb\"}",
          "legendFormat": "AbuseIPDB",
          "refId": "B"
        },
        {
          "expr": "enrichment_api_latency_seconds{quantile=\"0.5\", provider=\"otx\"}",
          "legendFormat": "AlienVault OTX",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "Queue Depth",
      "description": "Alerts waiting in the Redis queue",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 8,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "enrichment_queue_depth",
          "legendFormat": "Queue",
          "refId": "A"
        },
        {
          "expr": "enrichment_dlq_depth",
          "legendFormat": "Dead-Letter Queue",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Failed Alerts (DLQ)",
      "description": "Alerts that failed processing and were moved to the dead-letter queue",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "None",
                  "color": "green"
                }
              }
            }
          ]
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "enrichment_dlq_depth",
          "legendFormat": "DLQ Depth",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "CRITICAL Alerts (last 1h)",
      "description": "Number of CRITICAL risk alerts detected \u2014 triggers Slack alert",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "increase(enrichment_alerts_processed_total{risk_level=\"CRITICAL\"}[1h])",
          "legendFormat": "CRITICAL",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "title": "Total Alerts Processed",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(enrichment_alerts_processed_total)",
          "legendFormat": "Total",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "title": "API Error Rate",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(increase(enrichment_api_errors_total[1h]))",
          "legendFormat": "API Errors (1h)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Jira Resolved",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 100
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "jira_tickets_resolved",
          "legendFormat": "Resolved",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Jira In Progress",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 100
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": 0
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "jira_tickets_in_progress",
          "legendFormat": "In Progress",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Jira Tickets Over Time (Resolved vs In Progress)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 104
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Resolved"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "In Progress"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "jira_tickets_resolved",
          "legendFormat": "Resolved",
          "refId": "A"
        },
        {
          "expr": "jira_tickets_in_progress",
          "legendFormat": "In Progress",
          "refId": "B"
        }
      ]
    },
    {
      "id": 12,
      "title": "API Response Times per Provider (p50 / p90 / p99)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 104
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "enrichment_api_latency_seconds{quantile=\"0.5\", provider=\"virustotal\"}",
          "legendFormat": "VirusTotal p50",
          "refId": "A"
        },
        {
          "expr": "enrichment_api_latency_seconds{quantile=\"0.5\", provider=\"abuseipdb\"}",
          "legendFormat": "AbuseIPDB p50",
          "refId": "B"
        },
        {
          "expr": "enrichment_api_latency_seconds{quantile=\"0.5\", provider=\"otx\"}",
          "legendFormat": "AlienVault OTX p50",
          "refId": "C"
        },
        {
          "expr": "enrichment_api_latency_seconds{quantile=\"0.9\", provider=\"virustotal\"}",
          "legendFormat": "VirusTotal p90",
          "refId": "D"
        },
        {
          "expr": "enrichment_api_latency_seconds{quantile=\"0.9\", provider=\"abuseipdb\"}",
          "legendFormat": "AbuseIPDB p90",
          "refId": "E"
        },
        {
          "expr": "enrichment_api_latency_seconds{quantile=\"0.9\", provider=\"otx\"}",
          "legendFormat": "AlienVault OTX p90",
          "refId": "F"
        }
      ]
    }
  ],
  "alerting": {
    "alerts": [
      {
        "uid": "critical-alert-wazuh",
        "title": "CRITICAL IOC Alert Detected",
        "condition": "A",
        "data": [
          {
            "refId": "A",
            "queryType": "",
            "relativeTimeRange": {
              "from": 300,
              "to": 0
            },
            "datasourceUid": "prometheus",
            "model": {
              "expr": "increase(enrichment_alerts_processed_total{risk_level=\"CRITICAL\"}[5m])",
              "instant": true,
              "refId": "A"
            }
          }
        ],
        "intervalSeconds": 60,
        "noDataState": "OK",
        "execErrState": "Alerting",
        "for": "0s",
        "annotations": {
          "summary": "CRITICAL risk IOC detected by enrichment pipeline",
          "description": "A CRITICAL risk alert has been processed in the last 5 minutes. Immediate investigation required."
        },
        "labels": {
          "severity": "critical",
          "team": "security"
        }
      }
    ]
  }
}